---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.astro";

interface Props {
  title?: string;
  description?: string;
  lang?: "ko" | "en";
}

const {
  title = "ETERN Labs",
  description = "ETERN Labs showcases small static-first digital products by Legacy Revival Studio.",
  lang = "ko",
} = Astro.props;

const isEnglish = lang === "en";
const navItems = isEnglish
  ? [
      { href: "/en", label: "Home" },
      { href: "/en/products", label: "Products" },
      { href: "/en/contact", label: "Contact" },
    ]
  : [
      { href: "/", label: "홈" },
      { href: "/products", label: "제품" },
      { href: "/contact", label: "문의" },
    ];

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const currentPath = pathname === "/en" ? "/en" : pathname;
const isCurrent = (href: string) => currentPath === href;
const languageHref = isEnglish
  ? currentPath.replace(/^\/en/, "") || "/"
  : currentPath === "/"
    ? "/en"
    : `/en${currentPath}`;
const languageLabel = isEnglish ? "KO" : "EN";
const footerText = isEnglish
  ? "ETERN Labs, a static-first product showcase by Legacy Revival Studio."
  : "ETERN Labs는 Legacy Revival Studio의 정적 우선 제품 쇼케이스입니다.";
const subtitle = isEnglish
  ? "Small digital products, built to last."
  : "작지만 오래 남는 디지털 제품";
const brandHref = isEnglish ? "/en" : "/";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      // 페이지 로드 시 깜빡임 방지용 스크립트
      const getTheme = () => {
        const stored = localStorage.getItem("theme");
        if (stored && stored !== "system") return stored;
        return window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
      };
      if (getTheme() === "dark") {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }
    </script>
  </head>
  <body class="m-0 min-w-[320px]">
    <header
      class="flex items-center justify-between gap-6 py-6 w-[min(1120px,calc(100%-32px))] mx-auto sm:flex-row flex-col sm:items-center items-start"
    >
      <a class="flex items-center gap-3 no-underline" href={brandHref}>
        <span
          class="flex h-10 w-10 shrink-0 items-center justify-center border border-zinc-300 bg-zinc-950 text-sm font-semibold text-zinc-50 dark:border-zinc-700 dark:bg-white dark:text-black"
          >EL</span
        >
        <div class="flex flex-col">
          <span class="font-extrabold text-xl leading-tight">ETERN Labs</span>
          <span
            class="text-[10px] sm:text-xs text-muted font-medium leading-tight"
            >{subtitle}</span
          >
        </div>
      </a>
      <nav
        aria-label="Primary navigation"
        class="flex flex-wrap gap-2 justify-end sm:justify-end justify-start"
      >
        {
          navItems.map((item) => (
            <a
              href={item.href}
              aria-current={isCurrent(item.href) ? "page" : undefined}
              class:list={[
                "rounded-full text-muted px-3 py-2 no-underline hover:bg-panel hover:text-ink",
                { "bg-panel text-ink": isCurrent(item.href) },
              ]}
            >
              {item.label}
            </a>
          ))
        }
        <a
          class="flex items-center gap-1.5 rounded-full px-3 py-2 no-underline bg-panel text-ink border border-line font-bold hover:bg-page transition-colors"
          href={languageHref}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-4 h-4"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 2a14.5 14.5 0 0 0 0 20"></path>
            <path d="M2 12h20"></path>
          </svg>
          <span>{languageLabel}</span>
        </a>
        <ThemeToggle />
      </nav>
    </header>
    <main class="w-[min(1120px,calc(100%-32px))] mx-auto">
      <slot />
    </main>
    <footer
      class="border-top border-line mt-12 py-6 pb-10 w-[min(1120px,calc(100%-32px))] mx-auto"
    >
      <p class="text-sm m-0">{footerText}</p>
    </footer>
  </body>
</html>
