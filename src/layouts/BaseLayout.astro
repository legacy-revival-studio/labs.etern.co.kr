---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Legacy Revival Lab',
	description = 'Legacy Revival Lab showcases small static-first digital products by ETERN.',
} = Astro.props;

const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/products', label: 'Products' },
	{ href: '/contact', label: 'Contact' },
];
---

<!doctype html>
<html lang="ko">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header class="site-header">
			<a class="brand" href="/">Legacy Revival Lab</a>
			<nav aria-label="Primary navigation">
				{
					navItems.map((item) => (
						<a href={item.href} aria-current={Astro.url.pathname === item.href ? 'page' : undefined}>
							{item.label}
						</a>
					))
				}
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer class="site-footer">
			<p>Legacy Revival Lab, a static-first product showcase by ETERN.</p>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--color-ink: #171717;
		--color-muted: #5f646d;
		--color-line: #dedbd2;
		--color-page: #fbfaf7;
		--color-panel: #ffffff;
		--color-accent: #0f766e;
		--color-accent-dark: #115e59;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	html {
		background: var(--color-page);
		color: var(--color-ink);
	}

	body {
		margin: 0;
		min-width: 320px;
	}

	a {
		color: inherit;
	}

	main,
	.site-header,
	.site-footer {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
	}

	.site-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		padding: 24px 0;
	}

	.brand {
		font-weight: 800;
		text-decoration: none;
	}

	nav {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		justify-content: flex-end;
	}

	nav a {
		border-radius: 999px;
		color: var(--color-muted);
		padding: 8px 12px;
		text-decoration: none;
	}

	nav a:hover,
	nav a[aria-current='page'] {
		background: var(--color-panel);
		color: var(--color-ink);
	}

	section {
		padding: 56px 0;
	}

	.eyebrow {
		color: var(--color-accent);
		font-size: 0.8rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		margin: 0 0 12px;
		text-transform: uppercase;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1 {
		font-size: clamp(2.5rem, 7vw, 5rem);
		line-height: 0.98;
		margin-bottom: 24px;
		max-width: 820px;
	}

	h2 {
		font-size: clamp(1.8rem, 4vw, 3rem);
		line-height: 1.05;
		margin-bottom: 20px;
	}

	h3 {
		font-size: 1.15rem;
		margin-bottom: 10px;
	}

	p {
		color: var(--color-muted);
		font-size: 1rem;
		line-height: 1.7;
	}

	.lede {
		font-size: clamp(1.08rem, 2vw, 1.35rem);
		max-width: 720px;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 28px;
	}

	.button {
		align-items: center;
		background: var(--color-accent);
		border: 1px solid var(--color-accent);
		border-radius: 999px;
		color: #ffffff;
		display: inline-flex;
		font-weight: 700;
		justify-content: center;
		min-height: 44px;
		padding: 10px 18px;
		text-decoration: none;
	}

	.button:hover {
		background: var(--color-accent-dark);
		border-color: var(--color-accent-dark);
	}

	.button.secondary {
		background: transparent;
		color: var(--color-ink);
	}

	.button.secondary:hover {
		background: var(--color-panel);
		border-color: var(--color-line);
	}

	.grid {
		display: grid;
		gap: 16px;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
	}

	.card {
		background: var(--color-panel);
		border: 1px solid var(--color-line);
		border-radius: 8px;
		padding: 24px;
	}

	.site-footer {
		border-top: 1px solid var(--color-line);
		margin-top: 48px;
		padding: 24px 0 40px;
	}

	.site-footer p {
		font-size: 0.9rem;
		margin: 0;
	}

	@media (max-width: 640px) {
		.site-header {
			align-items: flex-start;
			flex-direction: column;
		}

		nav {
			justify-content: flex-start;
		}

		section {
			padding: 40px 0;
		}
	}
</style>
