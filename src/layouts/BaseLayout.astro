---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  lang?: "ko" | "en";
}

const {
  title = "Legacy Revival Lab",
  description = "Legacy Revival Lab showcases small static-first digital products by Legacy Revival Studio.",
  lang = "ko",
} = Astro.props;

const isEnglish = lang === "en";
const navItems = isEnglish
  ? [
      { href: "/en", label: "Home" },
      { href: "/en/products", label: "Products" },
      { href: "/en/contact", label: "Contact" },
    ]
  : [
      { href: "/", label: "홈" },
      { href: "/products", label: "제품" },
      { href: "/contact", label: "문의" },
    ];

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const currentPath = pathname === "/en" ? "/en" : pathname;
const isCurrent = (href: string) => currentPath === href;
const languageHref = isEnglish
  ? currentPath.replace(/^\/en/, "") || "/"
  : currentPath === "/"
    ? "/en"
    : `/en${currentPath}`;
const languageLabel = isEnglish ? "한국어" : "English";
const footerText = isEnglish
  ? "Legacy Revival Lab, a static-first product showcase by Legacy Revival Studio."
  : "Legacy Revival Lab은 Legacy Revival Studio의 정적 우선 제품 쇼케이스입니다.";
const brandHref = isEnglish ? "/en" : "/";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="m-0 min-w-[320px]">
    <header
      class="flex items-center justify-between gap-6 py-6 w-[min(1120px,calc(100%-32px))] mx-auto sm:flex-row flex-col sm:items-center items-start"
    >
      <a class="font-extrabold no-underline" href={brandHref}
        >Legacy Revival Lab</a
      >
      <nav
        aria-label="Primary navigation"
        class="flex flex-wrap gap-2 justify-end sm:justify-end justify-start"
      >
        {
          navItems.map((item) => (
            <a
              href={item.href}
              aria-current={isCurrent(item.href) ? "page" : undefined}
              class:list={[
                "rounded-full text-muted px-3 py-2 no-underline hover:bg-panel hover:text-ink",
                { "bg-panel text-ink": isCurrent(item.href) },
              ]}
            >
              {item.label}
            </a>
          ))
        }
        <a
          class="rounded-full px-3 py-2 no-underline bg-panel text-ink border border-line font-bold"
          href={languageHref}>{languageLabel}</a
        >
      </nav>
    </header>
    <main class="w-[min(1120px,calc(100%-32px))] mx-auto">
      <slot />
    </main>
    <footer
      class="border-top border-line mt-12 py-6 pb-10 w-[min(1120px,calc(100%-32px))] mx-auto"
    >
      <p class="text-sm m-0">{footerText}</p>
    </footer>
  </body>
</html>
